---
import Reveal from '~/components/Reveal.astro';
import type { Lang } from '~/i18n/routes';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;

const strings = lang === 'en'
  ? {
      sectionAria: 'Home',
      kicker: 'Digital craftsmanship',
      promiseLine1: 'Tools designed for your activity,',
      promiseLine2: 'useful to your clients, simple to live with daily.',
      cta: 'Discuss your project',
      contactHref: '/en/contact',
      scrollAria: 'Scroll to next section',
    }
  : {
      sectionAria: 'Accueil',
      kicker: 'Artisanat numérique',
      promiseLine1: 'Des outils pensés pour votre activité,',
      promiseLine2: 'utiles à vos clients, simples à vivre au quotidien.',
      cta: 'Échangeons sur votre projet',
      contactHref: '/contact',
      scrollAria: 'Défiler vers la suite',
    };
---

<section class="hero" aria-label={strings.sectionAria}>
  <img src="/LeGeai_logo_monochrome.svg" alt="" aria-hidden="true" class="hero-emblem" />

  <div class="hero-inner">
    <Reveal>
      <p class="kicker">{strings.kicker}</p>
    </Reveal>
    <Reveal delay={150}>
      <h1>
        <span class="title-line">Le Geai</span>
        <span class="title-sub">Informatique</span>
      </h1>
    </Reveal>
    <Reveal delay={300}>
      <p class="promise">
        {strings.promiseLine1}<br />
        {strings.promiseLine2}
      </p>
    </Reveal>
    <Reveal delay={450}>
      <a href={strings.contactHref} class="cta">
        <span>{strings.cta}</span>
      </a>
    </Reveal>
  </div>

  <div
    id="hero-line-zone"
    class="line-zone"
    role="button"
    tabindex="0"
    aria-label={strings.scrollAria}
  >
    <canvas id="hero-line-canvas" class="line-canvas" aria-hidden="true"></canvas>
  </div>
</section>

<script>
  const canvas = document.getElementById('hero-line-canvas') as HTMLCanvasElement | null;
  const zone = document.getElementById('hero-line-zone');
  const hero = canvas?.closest('.hero') as HTMLElement | null;

  if (canvas && zone && hero) {
    const ctx = canvas.getContext('2d');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (ctx && !reduceMotion) {
      let raf = 0;
      let pos = -40;
      let time = 0;
      let mouseActive = false;
      let tremor = 0;
      const speed = 0.6;
      const lineHalf = 36;
      const lineLen = 72;
      const segments = 28;

      const resize = () => {
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };
      resize();
      window.addEventListener('resize', resize);

      zone.addEventListener('mouseenter', () => { mouseActive = true; });
      zone.addEventListener('mouseleave', () => { mouseActive = false; });
      zone.addEventListener('focus', () => { mouseActive = true; });
      zone.addEventListener('blur', () => { mouseActive = false; });

      const scrollDown = () => {
        const next = hero.nextElementSibling as HTMLElement | null;
        if (next) next.scrollIntoView({ behavior: 'smooth' });
      };
      zone.addEventListener('click', scrollDown);
      zone.addEventListener('keydown', (e) => {
        const k = (e as KeyboardEvent).key;
        if (k === 'Enter' || k === ' ') {
          e.preventDefault();
          scrollDown();
        }
      });

      const draw = () => {
        const w = canvas.getBoundingClientRect().width;
        const h = canvas.getBoundingClientRect().height;
        ctx.clearRect(0, 0, w, h);
        time += 0.018;

        const target = mouseActive ? 1 : 0;
        tremor += (target - tremor) * 0.04;

        pos += speed;
        if (pos > h + lineHalf + 10) pos = -lineHalf - 10;

        const cx = w / 2;
        const points: { x: number; y: number }[] = [];
        for (let i = 0; i <= segments; i++) {
          const frac = i / segments;
          const py = pos - lineHalf + frac * lineLen;
          let px = cx;
          if (tremor > 0.005) {
            const f1 = Math.sin(time * 8 + frac * 12) * 1.8;
            const f2 = Math.sin(time * 13 + frac * 7) * 0.9;
            const f3 = Math.sin(time * 21 + frac * 19) * 0.4;
            const mid = Math.sin(frac * Math.PI);
            px += (f1 + f2 + f3) * tremor * mid;
          }
          points.push({ x: px, y: py });
        }

        ctx.beginPath();
        ctx.moveTo(points[0].x, points[0].y);
        for (let i = 1; i < points.length - 1; i++) {
          const xc = (points[i].x + points[i + 1].x) / 2;
          const yc = (points[i].y + points[i + 1].y) / 2;
          ctx.quadraticCurveTo(points[i].x, points[i].y, xc, yc);
        }
        const last = points[points.length - 1];
        ctx.lineTo(last.x, last.y);

        const top = points[0].y;
        const bot = last.y;
        const alpha = 0.7 + tremor * 0.15;
        const grad = ctx.createLinearGradient(0, top, 0, bot);
        grad.addColorStop(0, 'rgba(201, 169, 97, 0)');
        grad.addColorStop(0.1, `rgba(201, 169, 97, ${alpha * 0.5})`);
        grad.addColorStop(0.5, `rgba(201, 169, 97, ${alpha})`);
        grad.addColorStop(0.9, `rgba(201, 169, 97, ${alpha * 0.5})`);
        grad.addColorStop(1, 'rgba(201, 169, 97, 0)');

        ctx.strokeStyle = grad;
        ctx.lineWidth = 2.2 + tremor * 0.4;
        ctx.lineCap = 'round';
        ctx.stroke();

        if (tremor > 0.03) {
          ctx.save();
          ctx.shadowColor = `rgba(201, 169, 97, ${0.25 * tremor})`;
          ctx.shadowBlur = 10;
          ctx.strokeStyle = `rgba(201, 169, 97, ${0.1 * tremor})`;
          ctx.lineWidth = 4 + tremor * 2;
          ctx.stroke();
          ctx.restore();
        }

        raf = requestAnimationFrame(draw);
      };
      raf = requestAnimationFrame(draw);
    } else if (zone) {
      zone.addEventListener('click', () => {
        const next = hero.nextElementSibling as HTMLElement | null;
        if (next) next.scrollIntoView({ behavior: 'auto' });
      });
    }
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    padding: 6rem 1.5rem 4rem;
    text-align: center;
  }

  .hero-emblem {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(75vw, 600px);
    height: auto;
    transform: translate(-50%, -50%);
    opacity: 0.18;
    filter: brightness(1.6);
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .kicker {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-dore);
  }

  h1 {
    margin-top: 1.4rem;
  }
  .title-line {
    display: block;
    font-size: clamp(3.4rem, 9vw, 6rem);
    font-weight: 700;
    line-height: 0.95;
  }
  .title-sub {
    display: block;
    font-size: clamp(1.4rem, 3.4vw, 2rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
    margin-top: 0.4rem;
    letter-spacing: 0.18em;
  }

  .promise {
    margin-top: 2.6rem;
    font-style: italic;
    font-size: clamp(1.15rem, 2.4vw, 1.5rem);
    color: var(--color-text);
    line-height: 1.55;
  }

  .cta {
    display: inline-block;
    margin-top: 3rem;
    padding: 0.9rem 2.4rem;
    border: 1px solid var(--color-border);
    color: var(--color-dore);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: border-color 0.4s ease, color 0.4s ease, background 0.4s ease;
  }
  .cta:hover {
    border-color: var(--color-dore);
    color: var(--color-text);
    background: rgba(201, 169, 97, 0.06);
  }

  .line-zone {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 140px;
    cursor: pointer;
    z-index: 5;
  }
  .line-zone:focus-visible {
    outline: 2px solid var(--color-dore);
    outline-offset: 4px;
  }
  .line-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.5rem 4rem;
    }
    .line-zone {
      width: 160px;
      height: 120px;
    }
  }
</style>
