---
import { detectLang, routes, t } from '~/lib/i18n';

const current = Astro.url.pathname;
const lang = detectLang(current);
const strings = t(lang).footer;
const r = routes[lang];

const services = [
  { href: r.creation, label: strings.creation },
  { href: r.maintenance, label: strings.maintenance },
];

const links = [
  { href: r.mission, label: strings.mission },
  { href: r.tools, label: strings.tools },
  { href: r.portfolio, label: strings.portfolio },
  { href: r.blog, label: strings.blog },
  { href: r.faq, label: strings.faq },
  { href: r.contact, label: strings.contact },
  { href: r.links, label: strings.links },
  { href: r.legal, label: strings.legal },
  { href: r.privacy, label: strings.privacy },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <nav aria-label={strings.services} class="footer-services">
      {services.map((s) => <a href={s.href}>{s.label}</a>)}
    </nav>

    <nav aria-label={strings.secondary} class="footer-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <p class="footer-baseline">
      © {year} <a href="https://www.legeai-editions.com" target="_blank" rel="noopener">Le Geai</a>, {strings.rights}
      <br />
      <span class="legal">{strings.legalForm}</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 1.5rem 3rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .footer-inner {
    max-width: var(--container-default);
    margin-inline: auto;
    text-align: center;
  }
  .footer-services {
    display: flex;
    justify-content: center;
    gap: 2.2rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }
  .footer-services a {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }
  .footer-services a:hover {
    color: var(--color-dore);
  }
  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.6rem;
    flex-wrap: wrap;
    margin-bottom: 1.6rem;
  }
  .footer-links a {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    transition: color 0.3s ease;
  }
  .footer-links a:hover {
    color: var(--color-text-muted);
  }
  .footer-baseline {
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }
  .footer-baseline a {
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }
  .footer-baseline a:hover {
    color: var(--color-dore);
  }
  .legal {
    font-size: 0.78rem;
    font-style: italic;
    color: var(--color-text-dim);
  }
</style>
