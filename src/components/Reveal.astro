---
interface Props {
  delay?: number;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { delay = 0, as: Tag = 'div', class: className = '' } = Astro.props;
const style = delay > 0 ? `transition-delay: ${delay}ms` : undefined;
---

<Tag class={`reveal ${className}`.trim()} style={style}>
  <slot />
</Tag>
