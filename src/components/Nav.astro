---
import { detectLang, getAlternateUrl, routes, t } from '~/lib/i18n';

const current = Astro.url.pathname;
const currentLang = detectLang(current);
const strings = t(currentLang);
const r = routes[currentLang];

const links = [
  { href: r.creation, label: strings.nav.creation },
  { href: r.maintenance, label: strings.nav.maintenance },
  { href: r.tools, label: strings.nav.tools },
  { href: r.portfolio, label: strings.nav.portfolio },
  { href: r.blog, label: strings.nav.blog },
];

const mission = { href: r.mission, label: strings.nav.mission };
const cta = { href: r.contact, label: strings.nav.contact };

const alternateUrl = getAlternateUrl(current, currentLang);
const hasDirectTranslation = alternateUrl !== null;
const otherLang = currentLang === 'fr' ? 'en' : 'fr';

// Fallback : si pas de traduction directe, on pointe vers la home de l'autre langue
const fallbackUrl = otherLang === 'en' ? '/en' : '/';
const altUrl = alternateUrl ?? fallbackUrl;

const altTitle = hasDirectTranslation
  ? otherLang === 'en'
    ? 'English version of this page'
    : 'Version française de cette page'
  : otherLang === 'en'
    ? 'English home'
    : 'Accueil en français';

function isActive(href: string): boolean {
  if (href === '/' || href === '/en') return current === href;
  return current === href || current.startsWith(href + '/');
}

const homeHref = currentLang === 'en' ? '/en' : '/';
const brandLabel = currentLang === 'en'
  ? 'Le Geai Informatique, home'
  : 'Le Geai Informatique, accueil';
const navAriaLabel = currentLang === 'en' ? 'Main navigation' : 'Navigation principale';
const langSwitchLabel = currentLang === 'fr' ? 'English version →' : 'Version française →';
---

<nav id="main-nav" class="main-nav" aria-label={navAriaLabel}>
  <a href={homeHref} class="brand" aria-label={brandLabel}>
    <img src="/LeGeai_logo_monochrome.svg" alt="" class="brand-mark" />
    <span class="brand-name">Le Geai</span>
  </a>

  <ul class="nav-links">
    {links.map((l) => (
      <li>
        <a
          href={l.href}
          class:list={['nav-link', { 'is-current': isActive(l.href) }]}
          aria-current={current === l.href ? 'page' : undefined}
        >
          {l.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="nav-actions">
    <a
      href={mission.href}
      class:list={['nav-secondary', { 'is-current': isActive(mission.href) }]}
      aria-current={current === mission.href ? 'page' : undefined}
    >
      {mission.label}
    </a>

    <div class="lang-toggle" data-current-lang={currentLang} data-direct={hasDirectTranslation ? '1' : '0'}>
      {currentLang === 'fr' ? (
        <span class="lang-pill is-active" aria-current="true">FR</span>
      ) : (
        <a
          href={altUrl}
          class="lang-pill lang-link"
          hreflang="fr"
          title={altTitle}
        >FR</a>
      )}
      <span class="lang-sep" aria-hidden="true">·</span>
      {currentLang === 'en' ? (
        <span class="lang-pill is-active" aria-current="true">EN</span>
      ) : (
        <a
          href={altUrl}
          class="lang-pill lang-link"
          hreflang="en"
          title={altTitle}
        >EN</a>
      )}
    </div>

    <a
      href={cta.href}
      class:list={['nav-cta', { 'is-current': isActive(cta.href) }]}
      aria-current={current === cta.href ? 'page' : undefined}
    >
      {cta.label}
    </a>
  </div>

  <button
    type="button"
    id="burger"
    class="burger"
    aria-label={strings.nav.openMenu}
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <span></span><span></span><span></span>
  </button>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <ul>
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={{ 'is-current': isActive(l.href) }}
            aria-current={current === l.href ? 'page' : undefined}
          >{l.label}</a>
        </li>
      ))}
      <li>
        <a
          href={mission.href}
          class:list={{ 'is-current': isActive(mission.href) }}
          aria-current={current === mission.href ? 'page' : undefined}
        >{mission.label}</a>
      </li>
      <li class="mobile-cta-row">
        <a
          href={cta.href}
          class:list={['mobile-cta', { 'is-current': isActive(cta.href) }]}
        >{cta.label}</a>
      </li>
    </ul>
    <div class="mobile-lang">
      <a href={altUrl} hreflang={otherLang} title={altTitle}>{langSwitchLabel}</a>
    </div>
  </div>
</nav>

<script define:vars={{ openLabelFr: 'Ouvrir le menu', closeLabelFr: 'Fermer le menu', openLabelEn: 'Open menu', closeLabelEn: 'Close menu' }}>
  const nav = document.getElementById('main-nav');
  if (nav) {
    const onScroll = () => {
      const y = window.scrollY;
      nav.classList.toggle('is-scrolled', y > window.innerHeight * 0.12);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Hint discret quand le navigateur est dans l'autre langue ET qu'une trad directe existe.
  const langToggle = document.querySelector('.lang-toggle');
  if (langToggle) {
    const currentLang = langToggle.dataset.currentLang ?? 'fr';
    const hasDirectTranslation = langToggle.dataset.direct === '1';
    const dismissed = localStorage.getItem('lg_lang_hint_dismissed') === '1';

    if (hasDirectTranslation && !dismissed) {
      const browserLang = (navigator.language || '').toLowerCase().split('-')[0];
      const browserPrefersOther =
        (currentLang === 'fr' && browserLang === 'en') ||
        (currentLang === 'en' && browserLang === 'fr');

      if (browserPrefersOther) {
        langToggle.classList.add('has-hint');
        const otherLink = langToggle.querySelector('.lang-link');
        if (otherLink) {
          otherLink.addEventListener('click', () => {
            localStorage.setItem('lg_lang_hint_dismissed', '1');
          });
        }
        setTimeout(() => {
          langToggle.classList.remove('has-hint');
          localStorage.setItem('lg_lang_hint_dismissed', '1');
        }, 8000);
      }
    }
  }

  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  const isEn = (document.documentElement.lang || 'fr').startsWith('en');
  const openLabel = isEn ? openLabelEn : openLabelFr;
  const closeLabel = isEn ? closeLabelEn : closeLabelFr;
  if (burger && menu) {
    const closeMenu = () => {
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', openLabel);
      menu.setAttribute('hidden', '');
      document.body.style.overflow = '';
    };
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      if (open) {
        closeMenu();
      } else {
        burger.setAttribute('aria-expanded', 'true');
        burger.setAttribute('aria-label', closeLabel);
        menu.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
      }
    });
    for (const link of menu.querySelectorAll('a')) {
      link.addEventListener('click', closeMenu);
    }
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  }
</script>

<style>
  .main-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    /* Grid 3 colonnes : centre vraiment centré sur la page, indépendamment des largeurs latérales */
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    padding: 1.4rem 2.5rem;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background 0.5s ease, border-color 0.5s ease, padding 0.4s ease, backdrop-filter 0.5s ease;
  }
  .main-nav.is-scrolled {
    background: rgba(26, 26, 26, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--color-border);
    padding: 0.85rem 2.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-text);
    justify-self: start;
  }
  .brand-mark {
    width: 32px;
    height: auto;
    filter: brightness(2.4);
    transition: filter 0.4s ease;
  }
  .brand:hover .brand-mark {
    filter: brightness(2.4) drop-shadow(0 0 6px rgba(201, 169, 97, 0.45));
  }
  .brand-name {
    font-style: italic;
    font-size: 1.05rem;
    letter-spacing: 0.06em;
  }

  .nav-links {
    display: flex;
    gap: 1.8rem;
    list-style: none;
    justify-self: center;
  }
  .nav-link {
    position: relative;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.4s ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 1px;
    width: 0;
    background: var(--color-dore);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover,
  .nav-link.is-current {
    color: var(--color-text);
  }
  .nav-link:hover::after,
  .nav-link.is-current::after {
    width: 100%;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    justify-self: end;
  }

  /* Lien secondaire à droite (Mission) : discret, sans uppercase ni tracking lourd, en italique */
  .nav-secondary {
    font-size: 0.92rem;
    font-style: italic;
    color: var(--color-text-muted);
    transition: color 0.4s ease;
  }
  .nav-secondary:hover,
  .nav-secondary.is-current {
    color: var(--color-dore);
  }

  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    position: relative;
  }
  .lang-pill {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    transition: color 0.25s ease;
  }
  .lang-pill.is-active {
    color: var(--color-dore);
  }
  .lang-pill.lang-link {
    cursor: pointer;
    color: var(--color-text-muted);
  }
  .lang-pill.lang-link:hover { color: var(--color-dore); }
  .lang-sep { color: var(--color-text-dim); font-size: 0.7rem; opacity: 0.6; }

  .lang-toggle.has-hint::before {
    content: '';
    position: absolute;
    top: -6px;
    right: -8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-dore);
    box-shadow: 0 0 0 0 rgba(201, 169, 97, 0.6);
    animation: pulseHint 2.4s ease-out 1s 2;
  }
  @keyframes pulseHint {
    0% { box-shadow: 0 0 0 0 rgba(201, 169, 97, 0.55); }
    70% { box-shadow: 0 0 0 8px rgba(201, 169, 97, 0); }
    100% { box-shadow: 0 0 0 0 rgba(201, 169, 97, 0); }
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1.1rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dore);
    border: 1px solid var(--color-dore);
    background: transparent;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .nav-cta:hover {
    background: var(--color-dore);
    color: var(--color-noir);
  }
  .nav-cta.is-current {
    background: var(--color-dore);
    color: var(--color-noir);
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.4rem;
    z-index: 110;
  }
  .burger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--color-text);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    transform-origin: center;
  }
  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 105;
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 4rem 1.5rem;
  }
  .mobile-menu ul {
    list-style: none;
    text-align: center;
  }
  .mobile-menu li + li {
    margin-top: 0.5rem;
  }
  .mobile-menu a {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 1.4rem;
    font-style: italic;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }
  .mobile-menu a:hover,
  .mobile-menu a.is-current {
    color: var(--color-dore);
  }
  .mobile-cta-row {
    margin-top: 1.4rem !important;
    padding-top: 1.4rem;
    border-top: 1px solid var(--color-border);
  }
  .mobile-cta {
    padding: 0.75rem 1.6rem !important;
    font-size: 0.85rem !important;
    font-style: normal !important;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-dore) !important;
    border: 1px solid var(--color-dore);
  }
  .mobile-cta.is-current,
  .mobile-cta:hover {
    background: var(--color-dore);
    color: var(--color-noir) !important;
  }
  .mobile-lang {
    text-align: center;
    font-size: 0.85rem;
  }
  .mobile-lang a {
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
    font-style: italic;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .mobile-lang a:hover {
    color: var(--color-dore);
    border-bottom-color: var(--color-dore);
  }

  @media (max-width: 1100px) {
    .nav-links { gap: 1.4rem; }
    .nav-link { font-size: 0.7rem; letter-spacing: 0.14em; }
    .nav-secondary { font-size: 0.85rem; }
    .nav-actions { gap: 1.1rem; }
    .main-nav { padding: 1.2rem 1.8rem; gap: 1.2rem; }
    .main-nav.is-scrolled { padding: 0.75rem 1.8rem; }
  }

  @media (max-width: 900px) {
    .main-nav {
      grid-template-columns: auto 1fr auto;
      padding: 1.1rem 1.4rem;
      gap: 1rem;
    }
    .main-nav.is-scrolled {
      padding: 0.7rem 1.4rem;
    }
    .nav-links { display: none; }
    .nav-actions { display: none; }
    .burger { display: flex; justify-self: end; }
  }
</style>
