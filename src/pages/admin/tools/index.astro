---
import AdminLayout from '~/layouts/AdminLayout.astro';
import { directusFetch } from '~/lib/admin';

export const prerender = false;

const token = Astro.locals.adminToken!;
const ok = Astro.url.searchParams.get('ok');

interface ToolRow {
  id: string | number;
  status: string;
  name_fr: string;
  tagline_fr: string | null;
  tagline_en: string | null;
  description_fr: string | null;
  description_en: string | null;
  slug: string;
  version: string | null;
  download_count: number | null;
  downloads: { os: string; format: string }[] | null;
}

let tools: ToolRow[] = [];
let error: string | null = null;
try {
  const r = await directusFetch<{ data: ToolRow[] }>(
    token,
    '/items/tools?fields=id,status,name_fr,tagline_fr,tagline_en,description_fr,description_en,slug,version,download_count,downloads&sort=sort,name_fr&limit=200'
  );
  tools = r.data ?? [];
} catch (e) {
  error = String(e);
}

// Outil considéré "traduit" si la description EN est présente (le nom est partagé,
// la tagline est facultative — la description est le contenu textuel principal).
function isTranslated(t: ToolRow): boolean {
  return Boolean(t.description_en?.trim());
}
const translatedCount = tools.filter(isTranslated).length;

const STATUS_LABEL: Record<string, string> = {
  draft: 'Brouillon',
  published: 'Publié',
  archived: 'Archivé',
};
---

<AdminLayout title="Outils" active="tools">
  <h1 class="admin-h1">Logiciels et outils</h1>
  <p class="admin-sub">
    Création, mise à jour, gestion des fichiers téléchargeables.
    {tools.length > 0 && (
      <span class="trans-summary">
        · {translatedCount} / {tools.length} traduit{translatedCount > 1 ? 's' : ''} en anglais
      </span>
    )}
  </p>

  {ok === 'deleted' && <div class="admin-flash ok">Outil supprimé.</div>}

  <div class="admin-actions">
    <a href="/admin/tools/new" class="btn-primary-sm">+ Nouvel outil</a>
  </div>

  {error && <div class="admin-flash error">Erreur : {error}</div>}
  {!error && tools.length === 0 && <p class="empty">Aucun outil pour le moment. Cliquez sur « Nouvel outil » pour ajouter le premier.</p>}

  {tools.length > 0 && (
    <table class="admin-table">
      <thead>
        <tr>
          <th>Nom</th>
          <th>Langues</th>
          <th>Version</th>
          <th>Plateformes</th>
          <th>Téléchargements</th>
          <th>Statut</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {tools.map((t) => {
          const platforms = Array.from(new Set((t.downloads ?? []).map((d) => d.os)));
          const translated = isTranslated(t);
          return (
            <tr>
              <td>
                <a href={`/admin/tools/${t.id}`}>{t.name_fr || '(sans nom)'}</a>
                <div class="slug">/nos-outils#{t.slug}</div>
              </td>
              <td>
                <span class="lang-tag lang-fr">FR</span>
                <span class:list={['lang-tag', translated ? 'lang-en-on' : 'lang-en-off']}>EN</span>
              </td>
              <td>{t.version ?? '—'}</td>
              <td>
                {platforms.length === 0 ? '—' : (
                  <span class="platforms">
                    {platforms.map((p) => <span class="platform-tag">{p}</span>)}
                  </span>
                )}
              </td>
              <td><strong>{(t.download_count ?? 0).toLocaleString('fr-FR')}</strong></td>
              <td><span class={`badge badge-${t.status}`}>{STATUS_LABEL[t.status] ?? t.status}</span></td>
              <td>
                <a href={`/admin/tools/${t.id}`} class="row-action">Modifier</a>
                {t.status === 'published' && (
                  <a href={`/nos-outils`} target="_blank" rel="noopener" class="row-action">Voir</a>
                )}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  )}
</AdminLayout>

<style>
  .empty { text-align: center; padding: 3rem 0; font-style: italic; color: var(--color-text-muted); }
  .slug { font-size: 0.78rem; color: var(--color-text-dim); margin-top: 0.2rem; font-style: italic; }
  .platforms { display: inline-flex; gap: 0.3rem; flex-wrap: wrap; }
  .platform-tag {
    padding: 0.15rem 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }
  .row-action {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    margin-right: 0.4rem;
    transition: all 0.3s ease;
  }
  .row-action:hover { border-color: var(--color-dore); color: var(--color-dore); }
  .lang-tag {
    display: inline-block;
    padding: 0.18rem 0.5rem;
    margin-right: 0.3rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    border: 1px solid var(--color-border);
  }
  .lang-tag.lang-fr,
  .lang-tag.lang-en-on {
    color: var(--color-dore);
    border-color: var(--color-dore);
    background: rgba(201, 169, 97, 0.08);
  }
  .lang-tag.lang-en-off {
    color: var(--color-text-dim);
    opacity: 0.55;
    border-style: dashed;
  }
  .trans-summary { color: var(--color-text-dim); font-style: italic; }
</style>
