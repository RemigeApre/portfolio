---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import { getFaqs, setCacheHeaders, type Faq } from '~/lib/directus';
import { buildHreflang } from '~/lib/i18n';

setCacheHeaders(Astro.response.headers);

let faqs: Faq[] = [];
let error = false;
try {
  faqs = await getFaqs();
} catch (e) {
  console.error('Directus FAQ fetch failed', e);
  error = true;
}

const grouped = new Map<string, Faq[]>();
for (const f of faqs) {
  const key = f.category?.trim() || 'Général';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(f);
}
const categories = Array.from(grouped.entries());

const faqSchema = !error && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer.replace(/<[^>]*>/g, '').trim() },
      })),
    }
  : null;
---

<BaseLayout
  title="FAQ · Questions fréquentes"
  description="Réponses aux questions fréquentes sur la création web, la maintenance et l'accompagnement Le Geai Informatique."
  hreflang={buildHreflang('/faq', 'fr')}
>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}

  <header class="page-head">
    <div class="container-narrow">
      <Reveal>
        <h1>FAQ</h1>
      </Reveal>
      <Reveal delay={150}>
        <p class="lead">
          Si une question reste sans réponse, écrivez-nous, nous reviendrons vers
          vous sous 48h ouvrées.
        </p>
      </Reveal>
    </div>
  </header>

  <section class="list-wrap">
    <div class="container-narrow">
      {error && (
        <p class="empty">La FAQ est temporairement indisponible. Revenez dans un instant.</p>
      )}
      {!error && faqs.length === 0 && (
        <p class="empty">Les premières questions seront publiées prochainement.</p>
      )}
      {!error && faqs.length > 0 && (
        <div class="categories">
          {categories.map(([cat, items]) => (
            <Reveal class="category">
              {categories.length > 1 && <h2 class="category-title">{cat}</h2>}
              <ul class="qa-list">
                {items.map((f) => (
                  <li>
                    <details class="qa">
                      <summary>{f.question}</summary>
                      <div class="answer" set:html={f.answer}></div>
                    </details>
                  </li>
                ))}
              </ul>
            </Reveal>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cta">
    <div class="container-narrow">
      <Reveal>
        <h2>Une autre question</h2>
        <p class="lead">
          Décrivez votre situation, nous reviendrons avec une réponse précise.
        </p>
      </Reveal>
      <Reveal delay={150}>
        <div class="cta-row">
          <a href="/contact" class="btn-primary">Nous écrire</a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: 9rem 1.5rem 4rem;
    text-align: center;
  }
  .kicker {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-dore);
  }
  h1 {
    margin-top: 1.4rem;
    font-size: clamp(2.6rem, 6vw, 4.2rem);
  }
  .lead {
    max-width: 580px;
    margin: 1.4rem auto 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .list-wrap {
    padding: 2rem 1.5rem 4rem;
  }
  .empty {
    text-align: center;
    padding: 3rem 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .categories {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .category-title {
    font-size: 1.4rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-dore);
    text-align: left;
  }

  .qa-list {
    list-style: none;
  }
  .qa-list li + li {
    border-top: 1px solid var(--color-border);
  }
  .qa {
    padding: 1.2rem 0;
  }
  .qa summary {
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--color-text);
    list-style: none;
    position: relative;
    padding-right: 2rem;
    transition: color 0.3s ease;
  }
  .qa summary::-webkit-details-marker { display: none; }
  .qa summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    font-size: 1.5rem;
    color: var(--color-dore);
    transition: transform 0.3s ease;
    line-height: 1;
  }
  .qa[open] summary::after {
    content: '−';
  }
  .qa summary:hover {
    color: var(--color-dore);
  }
  .answer {
    margin-top: 1rem;
    color: var(--color-text-muted);
    line-height: 1.75;
  }
  .answer :global(p) { margin-bottom: 0.8rem; }
  .answer :global(p:last-child) { margin-bottom: 0; }
  .answer :global(a) {
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
  }
  .answer :global(ul), .answer :global(ol) {
    margin: 0.6rem 0 0.8rem 1.4rem;
  }

  .cta {
    padding: 5rem 1.5rem;
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  .cta h2 {
    font-size: clamp(1.6rem, 3vw, 2rem);
  }
  .cta-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-noir);
    background: var(--color-dore);
    transition: opacity 0.3s ease;
  }
  .btn-primary:hover { opacity: 0.85; }
</style>
