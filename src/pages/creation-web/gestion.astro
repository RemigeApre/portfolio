---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, creationFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('creation', 'gestion')!;
const index = creationFormules.findIndex((f) => f.slug === formule.slug) + 1;
---

<BaseLayout
  title="Site web Gestion dès 2 800 €"
  description="Formule Gestion : site avec espace administrateur, 1 à 3 fonctionnalités interactives (réservations, planning, espace client, stocks). Dès 2 800 €, 6 à 8 semaines."
  hreflang={buildHreflang('/creation-web/gestion', 'fr')}
>
  <FormuleDetail formule={formule} index={index} total={creationFormules.length} />
</BaseLayout>
