---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import { getFaqs, setCacheHeaders, faqQuestion, faqAnswer, faqCategory, type Faq } from '~/lib/directus';
import { buildHreflang } from '~/lib/i18n';

setCacheHeaders(Astro.response.headers);

let faqs: Faq[] = [];
let error = false;
try {
  faqs = await getFaqs();
} catch (e) {
  console.error('Directus FAQ fetch failed', e);
  error = true;
}

const grouped = new Map<string, Faq[]>();
for (const f of faqs) {
  const key = faqCategory(f, 'en')?.trim() || 'General';
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key)!.push(f);
}
const categories = Array.from(grouped.entries());

const faqSchema = !error && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: faqQuestion(f, 'en'),
        acceptedAnswer: { '@type': 'Answer', text: faqAnswer(f, 'en').replace(/<[^>]*>/g, '').trim() },
      })),
    }
  : null;

const hreflang = buildHreflang('/en/faq', 'en');
---

<BaseLayout
  title="FAQ · Frequent questions"
  description="Answers to frequent questions about web design, maintenance and the Le Geai Informatique engagement."
  lang="en"
  hreflang={hreflang}
>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}

  <header class="page-head">
    <div class="container-narrow">
      <Reveal>
        <h1>FAQ</h1>
      </Reveal>
      <Reveal delay={150}>
        <p class="lead">
          If a question stays unanswered, write to us; we shall come back
          within 48 working hours.
        </p>
      </Reveal>
    </div>
  </header>

  <section class="list-wrap">
    <div class="container-narrow">
      {error && (
        <p class="empty">The FAQ is temporarily unavailable. Come back in a moment.</p>
      )}
      {!error && faqs.length === 0 && (
        <p class="empty">The first questions will be published soon.</p>
      )}
      {!error && faqs.length > 0 && (
        <div class="categories">
          {categories.map(([cat, items]) => (
            <Reveal class="category">
              {categories.length > 1 && <h2 class="category-title">{cat}</h2>}
              <ul class="qa-list">
                {items.map((f) => {
                  const q = faqQuestion(f, 'en');
                  const a = faqAnswer(f, 'en');
                  const translated = Boolean(f.question_en?.trim() && f.answer_en?.trim());
                  return (
                    <li>
                      <details class="qa">
                        <summary lang={translated ? 'en' : 'fr'}>
                          {q}
                          {!translated && <span class="lang-badge" title="Originally in French">FR</span>}
                        </summary>
                        <div class="answer" lang={translated ? 'en' : 'fr'} set:html={a}></div>
                      </details>
                    </li>
                  );
                })}
              </ul>
            </Reveal>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="cta">
    <div class="container-narrow">
      <Reveal>
        <h2>Another question</h2>
        <p class="lead">
          Describe your situation, we shall come back with a precise answer.
        </p>
      </Reveal>
      <Reveal delay={150}>
        <div class="cta-row">
          <a href="/en/contact" class="btn-primary">Get in touch</a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { padding: 9rem 1.5rem 4rem; text-align: center; }
  h1 { margin-top: 1.4rem; font-size: clamp(2.6rem, 6vw, 4.2rem); }
  .lead {
    max-width: 580px;
    margin: 1.4rem auto 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .list-wrap { padding: 2rem 1.5rem 4rem; }
  .empty { text-align: center; padding: 3rem 0; font-style: italic; color: var(--color-text-muted); }

  .categories { display: flex; flex-direction: column; gap: 3rem; }
  .category-title {
    font-size: 1.4rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-dore);
    text-align: left;
  }

  .qa-list { list-style: none; }
  .qa-list li + li { border-top: 1px solid var(--color-border); }
  .qa { padding: 1.2rem 0; }
  .qa summary {
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--color-text);
    list-style: none;
    position: relative;
    padding-right: 2rem;
    transition: color 0.3s ease;
  }
  .qa summary::-webkit-details-marker { display: none; }
  .qa summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    font-size: 1.5rem;
    color: var(--color-dore);
    transition: transform 0.3s ease;
    line-height: 1;
  }
  .qa[open] summary::after { content: '−'; }
  .qa summary:hover { color: var(--color-dore); }
  .lang-badge {
    display: inline-block;
    margin-left: 0.6rem;
    padding: 0.1rem 0.45rem;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--color-text-dim);
    border: 1px solid var(--color-border);
    vertical-align: middle;
  }
  .answer { margin-top: 1rem; color: var(--color-text-muted); line-height: 1.75; }
  .answer :global(p) { margin-bottom: 0.8rem; }
  .answer :global(p:last-child) { margin-bottom: 0; }
  .answer :global(a) {
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
  }
  .answer :global(ul), .answer :global(ol) { margin: 0.6rem 0 0.8rem 1.4rem; }

  .cta {
    padding: 5rem 1.5rem;
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  .cta h2 { font-size: clamp(1.6rem, 3vw, 2rem); }
  .cta-row { display: flex; gap: 1rem; justify-content: center; margin-top: 2rem; }
  .btn-primary {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-noir);
    background: var(--color-dore);
    transition: opacity 0.3s ease;
  }
  .btn-primary:hover { opacity: 0.85; }
</style>
