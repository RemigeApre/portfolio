---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import ToolsList from '~/components/ToolsList.astro';
import { getTools, setCacheHeaders, type Tool } from '~/lib/directus';

setCacheHeaders(Astro.response.headers);

const SITE = 'https://www.legeai-informatique.fr';

let tools: Tool[] = [];
let error = false;
try {
  tools = await getTools();
} catch (e) {
  console.error('Tools fetch failed', e);
  error = true;
}

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${SITE}/en/our-tools#page`,
  url: `${SITE}/en/our-tools`,
  name: 'Our tools — Le Geai Informatique',
  description: 'Free, sober, open-source software made by Le Geai Informatique. Available for Windows, macOS, Linux, as web applications or browser extensions.',
  inLanguage: 'en-GB',
  publisher: { '@id': `${SITE}/#organization` },
  mainEntity: tools.map((t) => ({
    '@type': 'SoftwareApplication',
    name: t.name_fr,
    operatingSystem: t.app_type === 'desktop'
      ? Array.from(new Set((t.downloads ?? []).map((d) => d.os))).join(', ') || 'Windows, macOS, Linux'
      : 'Web',
    applicationCategory: t.app_type === 'extension' ? 'BrowserApplication' : t.app_type === 'web' ? 'WebApplication' : 'UtilitiesApplication',
    softwareVersion: t.version ?? undefined,
    description: t.description_en || t.description_fr || undefined,
    url: `${SITE}/en/our-tools/${t.slug}`,
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
    interactionStatistic: {
      '@type': 'InteractionCounter',
      interactionType: { '@type': 'DownloadAction' },
      userInteractionCount: t.download_count ?? 0,
    },
  })),
};
---

<BaseLayout
  title="Our tools · Free, sober, open software"
  description="Minimalist software crafted by Le Geai Informatique: no AI, no account, no connection unless explicitly stated. Open source, full IP retained. For Windows, macOS, Linux, as web apps or browser extensions."
  canonical={`${SITE}/en/our-tools`}
  lang="en"
  hreflang={[
    { lang: 'fr', href: '/nos-outils' },
    { lang: 'en', href: '/en/our-tools' },
    { lang: 'x-default', href: '/nos-outils' },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} slot="head" />

  <header class="page-head">
    <div class="container-narrow">
      <Reveal>
        <h1>Our tools</h1>
      </Reveal>
      <Reveal delay={150}>
        <p class="lead">A handful of pieces of software we have crafted, freely shared.</p>
      </Reveal>
      <Reveal delay={300}>
        <p class="lang-switch">
          <a href="/nos-outils" hreflang="fr" lang="fr">Version française →</a>
        </p>
      </Reveal>
    </div>
  </header>

  <section class="philosophy-collapse">
    <div class="container-narrow">
      <details class="phil-details">
        <summary class="phil-summary">
          <span class="phil-icon" aria-hidden="true">+</span>
          <span class="phil-text">Our approach: why these tools exist</span>
        </summary>
        <div class="phil-content">
          <div class="philosophy-text">
            <p>
              These tools were born first for our own use, to make life simpler,
              and out of the joy of crafting things. They exist; we may as well
              share them. That is the whole story.
            </p>
            <p>
              We retain full intellectual property. The code is open, so anyone
              can verify what they download.
            </p>
          </div>

          <ul class="principles">
            <li>
              <p class="num">I</p>
              <h3>Sober by exigence</h3>
              <p>
                A note-taking app weighs less than 80 kilobytes once installed.
                We would have liked to make it even smaller.
              </p>
            </li>
            <li>
              <p class="num">II</p>
              <h3>No AI, no account, no connection</h3>
              <p>
                No hidden artificial intelligence, no signup required, no server
                connection. Unless explicitly stated, your data never leaves
                your machine.
              </p>
            </li>
            <li>
              <p class="num">III</p>
              <h3>Open and verifiable code</h3>
              <p>
                Each tool ships with a link to its source code. You can inspect
                it, build it yourself, modify it for your needs.
              </p>
            </li>
            <li>
              <p class="num">IV</p>
              <h3>Answering a real need</h3>
              <p>
                Each tool was born from a concrete need. No piled-up features,
                no hidden subscription, no advertising splash screen.
              </p>
            </li>
          </ul>
        </div>
      </details>
    </div>
  </section>

  <section class="list-wrap">
    <div class="container">
      {error ? (
        <p class="error-state">Tools temporarily unavailable. Please come back in a moment.</p>
      ) : (
        <ToolsList tools={tools} lang="en" toolBaseHref="/en/our-tools" />
      )}
    </div>
  </section>

  <section class="cta">
    <div class="container-narrow">
      <Reveal>
        <h2>Suggestion or feedback</h2>
        <p class="cta-lead">
          Have a tool to suggest, feedback to share, a bug to report?
          Reach out, we read every message.
        </p>
      </Reveal>
      <Reveal delay={150}>
        <a href="/contact" class="btn-primary">Contact us</a>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding: 9rem 1.5rem 2rem;
    text-align: center;
  }
  h1 { font-size: clamp(2.6rem, 6vw, 4.2rem); }
  .lead {
    max-width: 600px;
    margin: 1.4rem auto 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
  .lang-switch { margin-top: 2rem; font-size: 0.85rem; }
  .lang-switch a {
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1px;
    transition: border-color 0.3s ease;
  }
  .lang-switch a:hover { border-bottom-color: var(--color-dore); }

  .philosophy-collapse {
    padding: 1rem 1.5rem 0;
  }
  .phil-details {
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    transition: border-color 0.3s ease;
  }
  .phil-details:hover { border-color: var(--color-border-hover); }
  .phil-details[open] { border-color: var(--color-dore); }

  .phil-summary {
    list-style: none;
    cursor: pointer;
    padding: 1rem 1.4rem;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--color-text-muted);
    transition: color 0.3s ease, background 0.3s ease;
  }
  .phil-summary::-webkit-details-marker { display: none; }
  .phil-summary::marker { display: none; content: ''; }
  .phil-summary:hover { color: var(--color-dore); }
  .phil-details[open] .phil-summary {
    background: rgba(201, 169, 97, 0.04);
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
  }

  .phil-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    font-size: 1.2rem;
    line-height: 1;
    color: var(--color-dore);
    flex-shrink: 0;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .phil-details[open] .phil-icon {
    transform: rotate(45deg);
    border-color: var(--color-dore);
  }

  .phil-content {
    padding: 2rem 2rem 2.5rem;
  }
  .philosophy-text {
    max-width: 600px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }
  .philosophy-text p {
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.85;
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .principles {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
    margin-top: 2rem;
  }
  .principles li {
    padding: 1.4rem 1.4rem 1.2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .principles .num {
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-dore);
    opacity: 0.65;
    margin-bottom: 0.4rem;
  }
  .principles h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .principles li p:last-child {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.92rem;
  }

  .list-wrap { padding: 2.5rem 1.5rem 6rem; }
  .error-state {
    text-align: center;
    padding: 4rem 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .cta {
    padding: 6rem 1.5rem;
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  .cta h2 { font-size: clamp(1.6rem, 3vw, 2rem); }
  .cta-lead {
    max-width: 520px;
    margin: 1.2rem auto 2rem;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.85rem 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-noir);
    background: var(--color-dore);
    transition: opacity 0.3s ease;
  }
  .btn-primary:hover { opacity: 0.85; }

  @media (max-width: 700px) {
    .principles { grid-template-columns: 1fr; }
  }
</style>
