---
import BaseLayout from '~/layouts/BaseLayout.astro';
import {
  getArticleBySlug,
  getArticles,
  assetUrl,
  setCacheHeaders,
  articleTitle,
  articleExcerpt,
  articleContent,
  articleHasTranslation,
  type Article,
} from '~/lib/directus';
import { tagColor } from '~/lib/tag-color';

setCacheHeaders(Astro.response.headers);

const SITE = 'https://www.legeai-informatique.fr';

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/en/blog', 307);
}

let article: Article | null = null;
let error = false;
try {
  article = await getArticleBySlug(slug);
} catch (e) {
  console.error('Directus article fetch failed', e);
  error = true;
}

if (!error && !article) {
  return new Response(null, { status: 404 });
}

let related: Article[] = [];
if (article) {
  try {
    const all = await getArticles();
    related = all.filter((a) => a.slug !== article!.slug).slice(0, 2);
  } catch {
    related = [];
  }
}

const dateFormatted = article?.date_published
  ? new Date(article.date_published).toLocaleDateString('en-GB', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const dateIso = article?.date_published ?? article?.date_updated ?? article?.date_created;

function readingTime(html: string | null | undefined): number {
  if (!html) return 1;
  const text = html.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
  const words = text.split(' ').filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const enTitle = article ? articleTitle(article, 'en') : '';
const enExcerpt = article ? articleExcerpt(article, 'en') : null;
const enContent = article ? articleContent(article, 'en') : null;
const translated = article ? articleHasTranslation(article, 'en') : false;
const minutes = article ? readingTime(enContent) : 0;

const cover = article ? assetUrl(article.cover) : null;
const ogImage = cover ?? '/LeGeai_logo_monochrome.svg';

const articleUrl = article ? `${SITE}/en/blog/${article.slug}` : SITE;
const safeHeadline = enTitle.slice(0, 110);

const articleJsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      '@id': `${articleUrl}#post`,
      headline: safeHeadline,
      description: enExcerpt ?? undefined,
      datePublished: article.date_published ?? undefined,
      dateModified: article.date_updated ?? article.date_published ?? undefined,
      url: articleUrl,
      mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
      author: {
        '@type': 'Organization',
        '@id': `${SITE}/#organization`,
        name: article.author ?? 'Le Geai · editorial',
        url: `${SITE}/en/mission`,
      },
      publisher: {
        '@type': 'Organization',
        '@id': `${SITE}/#organization`,
        name: 'Le Geai Informatique',
        logo: {
          '@type': 'ImageObject',
          url: `${SITE}/LeGeai_logo_monochrome.svg`,
        },
      },
      image: cover ?? `${SITE}/LeGeai_logo_monochrome.svg`,
      inLanguage: translated ? 'en-GB' : 'fr-FR',
      keywords: article.tags && article.tags.length > 0 ? article.tags.join(', ') : undefined,
      articleSection: 'The journal',
      articleBody: enContent ? enContent.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim().slice(0, 5000) : undefined,
      wordCount: enContent ? enContent.replace(/<[^>]*>/g, ' ').split(/\s+/).filter(Boolean).length : undefined,
      timeRequired: `PT${minutes}M`,
      isAccessibleForFree: true,
      copyrightHolder: { '@type': 'Organization', name: 'Le Geai' },
      copyrightYear: article.date_published ? new Date(article.date_published).getFullYear() : new Date().getFullYear(),
      speakable: {
        '@type': 'SpeakableSpecification',
        cssSelector: ['h1', '.content p:first-of-type'],
      },
    }
  : null;

const breadcrumbJsonLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/en` },
        { '@type': 'ListItem', position: 2, name: 'The journal', item: `${SITE}/en/blog` },
        { '@type': 'ListItem', position: 3, name: enTitle, item: articleUrl },
      ],
    }
  : null;

const hreflang = article ? [
  { lang: 'fr', href: `/blog/${article.slug}` },
  { lang: 'en', href: `/en/blog/${article.slug}` },
  { lang: 'x-default', href: `/blog/${article.slug}` },
] : undefined;
---

<BaseLayout
  title={article ? enTitle : 'Article unavailable'}
  description={enExcerpt ?? 'Article from the Le Geai Informatique journal.'}
  canonical={articleUrl}
  ogImage={ogImage}
  ogType="article"
  lang={translated ? 'en' : 'fr'}
  hreflang={hreflang}
  articleMeta={article ? {
    publishedTime: article.date_published ?? null,
    modifiedTime: article.date_updated ?? article.date_published ?? null,
    author: article.author ?? 'Le Geai · editorial',
    tags: article.tags ?? null,
  } : undefined}
>
  {articleJsonLd && <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} slot="head" />}
  {breadcrumbJsonLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />}

  {error && (
    <section class="container-narrow message">
      <h1>Article temporarily unavailable</h1>
      <p>An error occurred while loading. Come back in a moment.</p>
      <a href="/en/blog" class="btn-ghost">Back to the journal</a>
    </section>
  )}

  {article && (
    <article class="post" itemscope itemtype="https://schema.org/BlogPosting">
      <header class="post-head">
        <div class="container-narrow">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/en/blog" class="back-link">← All articles</a>
          </nav>
          {!translated && (
            <p class="lang-notice">
              This article has not been translated to English yet. Reading it in French.
              <a href={`/blog/${article.slug}`} hreflang="fr">Lire en français →</a>
            </p>
          )}
          <h1 itemprop="headline" lang={translated ? 'en' : 'fr'}>{enTitle}</h1>
          {dateFormatted && (
            <time class="sr-only" datetime={dateIso} itemprop="datePublished">{dateFormatted}</time>
          )}
          {article.author && (
            <span class="sr-only" itemprop="author">{article.author}</span>
          )}
          <p class="meta">
            <span class="reading-time">{minutes} min read</span>
          </p>
          {article.tags && article.tags.length > 0 && (
            <ul class="tags" aria-label="Tags">
              {article.tags.map((tag) => (
                <li class={`tag tag-${tagColor(tag)}`}>{tag}</li>
              ))}
            </ul>
          )}
        </div>
      </header>

      {cover && (
        <figure class="cover">
          <img src={cover} alt={enTitle} itemprop="image" />
        </figure>
      )}

      <div
        class="content"
        itemprop="articleBody"
        lang={translated ? 'en' : 'fr'}
        set:html={enContent ?? ''}
      />

      <aside class="byline container-narrow">
        <p>
          Published by <strong>{article.author ?? 'Le Geai · editorial'}</strong>.
          <a href="/en/mission">Le Geai Informatique</a> is the digital branch
          of Le Geai, a publishing house. A vision: minimalist, secure, turned
          towards use and beauty.
        </p>
      </aside>

      {related.length > 0 && (
        <section class="related">
          <div class="container-narrow">
            <h2 class="related-title">Also read</h2>
            <ul class="related-list">
              {related.map((r) => (
                <li>
                  <a href={`/en/blog/${r.slug}`}>
                    <span class="related-name">{articleTitle(r, 'en')}</span>
                    {articleExcerpt(r, 'en') && <span class="related-excerpt">{articleExcerpt(r, 'en')}</span>}
                    <span class="related-cta" aria-hidden="true">Read →</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      <footer class="post-foot container-narrow">
        <a href="/en/blog" class="btn-ghost">← All articles</a>
        <a href="/en/contact" class="btn-primary">Discuss your project</a>
      </footer>
    </article>
  )}
</BaseLayout>

<style>
  .message { padding: 8rem 1.5rem 6rem; text-align: center; }
  .message h1 { margin-bottom: 1rem; }
  .message p { color: var(--color-text-muted); margin-bottom: 2rem; }

  .post { padding-top: 8rem; }

  .post-head { text-align: center; padding: 0 1.5rem 3rem; }
  .breadcrumb {
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .lang-notice {
    max-width: 620px;
    margin: 0 auto 2rem;
    padding: 0.8rem 1.2rem;
    background: rgba(201, 169, 97, 0.06);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.9rem;
    text-align: center;
  }
  .lang-notice a {
    color: var(--color-dore);
    margin-left: 0.6rem;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.3s ease;
  }
  .lang-notice a:hover { border-bottom-color: var(--color-dore); }
  .back-link {
    color: var(--color-dore);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
  }
  .back-link:hover { border-bottom-color: var(--color-dore); }

  h1 {
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.15;
    max-width: 800px;
    margin: 0 auto;
  }

  .meta {
    margin-top: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .reading-time {
    color: var(--color-dore);
    position: relative;
    padding: 0 1.2rem;
  }
  .reading-time::before, .reading-time::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 24px;
    height: 1px;
    background: var(--color-border);
  }
  .reading-time::before { right: 100%; }
  .reading-time::after { left: 100%; }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.6rem;
  }

  .cover {
    margin: 3rem auto 4rem;
    max-width: 900px;
    padding: 0 1.5rem;
  }
  .cover img {
    width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
  }

  .content {
    max-width: 680px;
    margin: 3rem auto 0;
    padding: 0 1.5rem;
    color: var(--color-text);
    font-family: var(--font-reading);
    font-weight: 400;
    line-height: 1.78;
    font-size: 1.18rem;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }
  .content :global(p:first-of-type) { text-align: left; }
  .content :global(p:first-of-type::first-letter) {
    font-size: 4.2rem;
    font-style: italic;
    color: var(--color-dore);
    font-weight: 500;
    line-height: 0.85;
    float: left;
    margin: 0.4rem 0.7rem 0 0;
  }

  .content :global(h2) {
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-size: 1.8rem;
    color: var(--color-text);
    line-height: 1.25;
    position: relative;
    padding-bottom: 0.6rem;
  }
  .content :global(h2)::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 36px;
    height: 1px;
    background: var(--color-dore);
  }
  .content :global(h3) {
    margin-top: 2.2rem;
    margin-bottom: 0.8rem;
    font-size: 1.3rem;
    color: var(--color-text);
  }
  .content :global(p) { margin-bottom: 1.4rem; }
  .content :global(a) {
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.3s ease;
  }
  .content :global(a:hover) { border-bottom-color: var(--color-dore); }
  .content :global(strong) { color: var(--color-text); font-weight: 700; }
  .content :global(em) { font-style: italic; color: var(--color-dore); }
  .content :global(blockquote) {
    margin: 2.5rem 0;
    padding: 0.5rem 2rem;
    border-left: 2px solid var(--color-dore);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }
  .content :global(ul), .content :global(ol) { margin: 1rem 0 1.6rem 1.6rem; }
  .content :global(li) { margin-bottom: 0.6rem; padding-left: 0.4rem; }
  .content :global(ul li::marker) { color: var(--color-dore); }
  .content :global(ol li::marker) { color: var(--color-dore); font-style: italic; }
  .content :global(img) {
    margin: 2.5rem auto;
    border: 1px solid var(--color-border);
    max-width: 100%;
    height: auto;
  }
  .content :global(figure) { margin: 2.5rem 0; }
  .content :global(figcaption) {
    margin-top: 0.6rem;
    text-align: center;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-text-dim);
  }
  .content :global(code) {
    padding: 0.15rem 0.4rem;
    background: var(--color-surface-raised);
    border-radius: 2px;
    font-size: 0.92em;
    font-family: ui-monospace, "Cascadia Code", "Courier New", monospace;
  }
  .content :global(pre) {
    margin: 2rem 0;
    padding: 1.2rem 1.5rem;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .content :global(pre code) { background: none; padding: 0; }
  .content :global(hr) {
    margin: 3rem auto;
    width: 60px;
    border: none;
    border-top: 1px solid var(--color-dore);
    opacity: 0.4;
  }

  .byline {
    margin-top: 4rem;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .byline p {
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.7;
    text-align: center;
    max-width: 620px;
    margin: 0 auto;
  }
  .byline strong { color: var(--color-dore); font-weight: 700; font-style: normal; }
  .byline a {
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.3s ease;
  }
  .byline a:hover { border-bottom-color: var(--color-dore); }

  .related { padding: 4rem 1.5rem 2rem; background: var(--color-surface-raised); }
  .related-title {
    font-size: 1.4rem;
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 2rem;
  }
  .related-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  .related-list li a {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: inherit;
    height: 100%;
    transition: all 0.3s ease;
  }
  .related-list li a:hover {
    border-color: var(--color-dore);
    transform: translateY(-2px);
  }
  .related-name {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
    transition: color 0.3s ease;
  }
  .related-list li a:hover .related-name { color: var(--color-dore); }
  .related-excerpt {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    font-style: italic;
  }
  .related-cta {
    margin-top: auto;
    padding-top: 0.6rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .related-list li a:hover .related-cta { color: var(--color-dore); }

  .post-foot {
    padding: 3rem 1.5rem 6rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary, .btn-ghost {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: all 0.4s ease;
  }
  .btn-primary { color: var(--color-noir); background: var(--color-dore); }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost { color: var(--color-text); border: 1px solid var(--color-border); }
  .btn-ghost:hover { border-color: var(--color-dore); color: var(--color-dore); }

  @media (max-width: 700px) {
    .content { font-size: 1.05rem; padding: 0 1.2rem; }
    .content :global(p:first-of-type::first-letter) { font-size: 3.4rem; }
    .content :global(h2) { font-size: 1.5rem; }
    .related-list { grid-template-columns: 1fr; }
  }
</style>
