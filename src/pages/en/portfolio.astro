---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import {
  getRealisations,
  assetUrl,
  setCacheHeaders,
  realisationTitle,
  realisationDescription,
  type Realisation,
} from '~/lib/directus';
import { buildHreflang } from '~/lib/i18n';

setCacheHeaders(Astro.response.headers);

let realisations: Realisation[] = [];
let error = false;
try {
  realisations = await getRealisations();
} catch (e) {
  console.error('Directus realisations fetch failed', e);
  error = true;
}

const hreflang = buildHreflang('/en/portfolio', 'en');
---

<BaseLayout
  title="Portfolio · Le Geai Informatique"
  description="Le Geai Informatique works: websites, management areas, e-commerce, custom software for independents, artisans and small firms."
  lang="en"
  hreflang={hreflang}
>
  <header class="page-head">
    <div class="container-narrow">
      <Reveal>
        <h1>Portfolio</h1>
      </Reveal>
      <Reveal delay={150}>
        <p class="lead">
          Different settings, the same exigences: a clear use, a reliable
          tool, a lasting presence.
        </p>
      </Reveal>
    </div>
  </header>

  <section class="list-wrap">
    <div class="container">
      {error && (
        <p class="empty">The portfolio is temporarily unavailable. Come back in a moment.</p>
      )}
      {!error && realisations.length === 0 && (
        <p class="empty">The first works will be published soon.</p>
      )}
      {!error && realisations.length > 0 && (
        <ul class="grid">
          {realisations.map((r, i) => {
            const cover = assetUrl(r.cover);
            const title = realisationTitle(r, 'en');
            const desc = realisationDescription(r, 'en');
            return (
              <Reveal delay={50 + i * 60} class="grid-item">
                {r.url ? (
                  <a href={r.url} target="_blank" rel="noopener" class="card">
                    {cover && <img src={cover} alt="" class="card-cover" loading="lazy" />}
                    <div class="card-body">
                      {r.client && <p class="card-client">{r.client}</p>}
                      <h2>{title}</h2>
                      {desc && <p class="card-desc">{desc}</p>}
                      {r.tags && r.tags.length > 0 && (
                        <ul class="tags" aria-label="Tags">
                          {r.tags.map((t) => (
                            <li>{t}</li>
                          ))}
                        </ul>
                      )}
                      <p class="card-cta">Visit the project</p>
                    </div>
                  </a>
                ) : (
                  <div class="card card-static">
                    {cover && <img src={cover} alt="" class="card-cover" loading="lazy" />}
                    <div class="card-body">
                      {r.client && <p class="card-client">{r.client}</p>}
                      <h2>{title}</h2>
                      {desc && <p class="card-desc">{desc}</p>}
                      {r.tags && r.tags.length > 0 && (
                        <ul class="tags" aria-label="Tags">
                          {r.tags.map((t) => (
                            <li>{t}</li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </div>
                )}
              </Reveal>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { padding: 9rem 1.5rem 4rem; text-align: center; }
  h1 { margin-top: 1.4rem; font-size: clamp(2.6rem, 6vw, 4.2rem); }
  .lead {
    max-width: 580px;
    margin: 1.4rem auto 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .list-wrap { padding: 2rem 1.5rem 6rem; }
  .empty {
    text-align: center;
    padding: 3rem 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.4rem;
    margin-top: 2rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    transition: all 0.4s ease;
  }
  .card:not(.card-static):hover {
    border-color: var(--color-dore);
    transform: translateY(-3px);
  }
  .card-cover { width: 100%; height: 200px; object-fit: cover; }
  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-client {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-dore);
    opacity: 0.8;
  }
  .card h2 { margin-top: 0.6rem; font-size: 1.4rem; }
  .card-desc { margin-top: 0.8rem; color: var(--color-text-muted); line-height: 1.6; }
  .tags { list-style: none; display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
  .tags li {
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--color-border);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .card-cta {
    margin-top: auto;
    padding-top: 1.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.3s ease;
  }
  .card:hover .card-cta { color: var(--color-dore); }
</style>
