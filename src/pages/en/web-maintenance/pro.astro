---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('maintenance', 'pro', 'en')!;
const index = maintenanceFormules.findIndex((f) => f.slug === formule.slug) + 1;
const hreflang = buildHreflang('/en/web-maintenance/pro', 'en');
---

<BaseLayout
  title="Pro web maintenance · €149 / month"
  description="Pro level: Essential + 2 hours of monthly improvement on request (design, features, content, SEO). €149 net per month, 12-month engagement."
  lang="en"
  hreflang={hreflang}
>
  <FormuleDetail formule={formule} index={index} total={maintenanceFormules.length} lang="en" />
</BaseLayout>
