---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('maintenance', 'legendary', 'en')!;
const index = maintenanceFormules.findIndex((f) => f.slug === formule.slug) + 1;
const hreflang = buildHreflang('/en/web-maintenance/legendary', 'en');
---

<BaseLayout
  title="Legendary web maintenance · €499 / month"
  description="Legendary level: Premium + 1 hour weekly active content management, maximum priority. €499 net per month, 12-month engagement."
  lang="en"
  hreflang={hreflang}
>
  <FormuleDetail formule={formule} index={index} total={maintenanceFormules.length} lang="en" />
</BaseLayout>
