---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('maintenance', 'essential', 'en')!;
const index = maintenanceFormules.findIndex((f) => f.slug === formule.slug) + 1;
const hreflang = buildHreflang('/en/web-maintenance/essential', 'en');
---

<BaseLayout
  title="Essential web maintenance · €39 / month"
  description="Essential level: domain, hosting, SSL, monthly backup of structure, monitoring, fixing of blocking incidents. €39 net per month, 12-month engagement."
  lang="en"
  hreflang={hreflang}
>
  <FormuleDetail formule={formule} index={index} total={maintenanceFormules.length} lang="en" />
</BaseLayout>
