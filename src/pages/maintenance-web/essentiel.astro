---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('maintenance', 'essentiel')!;
const index = maintenanceFormules.findIndex((f) => f.slug === formule.slug) + 1;
---

<BaseLayout
  title="Essentiel · Maintenance web 39 € par mois"
  description="Maintenance Essentiel : nom de domaine, hébergement, SSL, sauvegarde mensuelle, surveillance, correction des incidents bloquants. 39 € par mois, engagement 12 mois."
  hreflang={buildHreflang('/maintenance-web/essentiel', 'fr')}
>
  <FormuleDetail formule={formule} index={index} total={maintenanceFormules.length} />
</BaseLayout>
