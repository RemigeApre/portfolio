---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('maintenance', 'premium')!;
const index = maintenanceFormules.findIndex((f) => f.slug === formule.slug) + 1;
---

<BaseLayout
  title="Premium · Maintenance web 299 € par mois"
  description="Maintenance Premium : Pro + sauvegarde complète + 4 h supplémentaires + 1 h de formation utilisateur + intervention sous 24 h ouvrées. 299 € par mois, engagement 12 mois."
  hreflang={buildHreflang('/maintenance-web/premium', 'fr')}
>
  <FormuleDetail formule={formule} index={index} total={maintenanceFormules.length} />
</BaseLayout>
