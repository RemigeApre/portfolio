---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import { maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const SITE = 'https://www.legeai-informatique.fr';

// OfferCatalog : signale Google que /maintenance-web est l'index des offres,
// chaque sous-page hostée son propre Service individuel.
const offerCatalog = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  '@id': `${SITE}/maintenance-web#catalog`,
  name: 'Formules de maintenance web Le Geai Informatique',
  url: `${SITE}/maintenance-web`,
  inLanguage: 'fr-FR',
  provider: { '@id': `${SITE}/#organization` },
  itemListElement: maintenanceFormules.map((f) => {
    const priceNum = f.tarifShort.match(/\d[\d ]*/)?.[0]?.replace(/\s/g, '');
    return {
      '@type': 'Offer',
      '@id': `${SITE}/maintenance-web/${f.slug}#service`,
      name: f.name,
      url: `${SITE}/maintenance-web/${f.slug}`,
      description: f.compositionShort,
      ...(priceNum ? {
        price: priceNum,
        priceCurrency: 'EUR',
        availability: 'https://schema.org/InStock',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          price: priceNum,
          priceCurrency: 'EUR',
          billingIncrement: 1,
          unitCode: 'MON',
        },
      } : {}),
    };
  }),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'Maintenance web', item: `${SITE}/maintenance-web` },
  ],
};

type Cell = boolean | string;
interface Group {
  title: string;
  rows: { feature: string; cells: [Cell, Cell, Cell, Cell] }[];
}

const groups: Group[] = [
  {
    title: 'Socle technique',
    rows: [
      { feature: 'Nom de domaine', cells: [true, true, true, true] },
      { feature: 'Hébergement', cells: [true, true, true, true] },
      { feature: 'Certificat SSL', cells: [true, true, true, true] },
      { feature: 'Surveillance continue', cells: [true, true, true, true] },
      { feature: 'Correction des incidents bloquants', cells: [true, true, true, true] },
    ],
  },
  {
    title: 'Sauvegardes',
    rows: [
      { feature: 'Sauvegarde de la structure', cells: ['mensuelle', 'mensuelle', 'mensuelle', 'mensuelle'] },
      { feature: 'Sauvegarde du contenu', cells: [false, false, true, true] },
    ],
  },
  {
    title: 'Améliorations sur demande',
    rows: [
      { feature: 'Heures incluses chaque mois', cells: [false, '2 h', '6 h', '6 h'] },
      { feature: 'Périmètre couvert', cells: [false, 'design, fonctionnalités, contenu, SEO', 'design, fonctionnalités, contenu, SEO', 'design, fonctionnalités, contenu, SEO'] },
    ],
  },
  {
    title: 'Accompagnement',
    rows: [
      { feature: 'Formation utilisateur', cells: [false, false, '1 h / mois', '1 h / mois'] },
      { feature: 'Gestion active du contenu', cells: [false, false, false, '1 h / semaine'] },
      { feature: "Délai d'intervention", cells: ['standard', 'standard', '24 h ouvrées', 'priorité maximale'] },
    ],
  },
];

const renderCell = (c: Cell) => {
  if (c === true) return { mark: '✓', text: '', cls: 'cell-yes' };
  if (c === false) return { mark: '—', text: '', cls: 'cell-no' };
  return { mark: '', text: c, cls: 'cell-text' };
};
---

<BaseLayout
  title="Maintenance web mensuelle"
  description="Maintenance web hébergement et domaine inclus. Quatre niveaux : Essentiel 39 €, Pro 149 €, Premium 299 €, Légendaire 499 € par mois."
  hreflang={buildHreflang('/maintenance-web', 'fr')}
>
  <script type="application/ld+json" set:html={JSON.stringify(offerCatalog)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />
  <header class="page-head">
    <div class="container-narrow">
      <Reveal>
        <h1>Votre site reste vivant, sécurisé et à jour</h1>
      </Reveal>
      <Reveal delay={150}>
        <p class="lead">
          La technique reste de notre côté. Quatre niveaux d'engagement, du socle
          essentiel à la gestion active hebdomadaire.
        </p>
      </Reveal>
    </div>
  </header>

  <section class="formules-row">
    <h2 class="sr-only">Les quatre niveaux de maintenance</h2>
    <div class="container">
      <div class="cards-grid">
        {maintenanceFormules.map((f, i) => (
          <Reveal delay={80 + i * 60}>
            <a href={`/maintenance-web/${f.slug}`} class="card-link">
              <article class="card">
                <h3>{f.name}</h3>
                <p class="card-tarif">{f.tarifLong}</p>
                <p class="card-meta">{f.delai}</p>
                <span class="card-arrow" aria-hidden="true">→</span>
              </article>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="comparator-section">
    <div class="container">
      <Reveal>
        <h2 class="comparator-title">Comparatif</h2>
        <p class="comparator-hint" aria-hidden="true">
          Cliquez sur le nom d'une formule pour voir le détail.
        </p>
      </Reveal>

      <Reveal delay={100}>
        <div class="table-wrap">
          <table class="comparator">
            <thead>
              <tr>
                <th class="feature-col" scope="col"><span class="sr-only">Fonctionnalité</span></th>
                {maintenanceFormules.map((f) => (
                  <th class="formule-col" scope="col">
                    <a href={`/maintenance-web/${f.slug}`} class="formule-link">
                      <span class="formule-name">{f.name}</span>
                      <span class="formule-tarif">{f.tarifShort}</span>
                    </a>
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {groups.map((g) => (
                <>
                  <tr class="group-row">
                    <th colspan={5} scope="colgroup">{g.title}</th>
                  </tr>
                  {g.rows.map((r) => (
                    <tr>
                      <th scope="row" class="feature">{r.feature}</th>
                      {r.cells.map((c) => {
                        const v = renderCell(c);
                        return (
                          <td class={v.cls}>
                            {v.mark && <span class="cell-mark" aria-hidden="true">{v.mark}</span>}
                            {v.text && <span class="cell-value">{v.text}</span>}
                            <span class="sr-only">
                              {c === true ? 'inclus' : c === false ? 'non inclus' : c}
                            </span>
                          </td>
                        );
                      })}
                    </tr>
                  ))}
                </>
              ))}

              <tr class="summary-row">
                <th scope="row" class="feature">Tarif mensuel</th>
                {maintenanceFormules.map((f) => (
                  <td class="cell-tarif">{f.tarifShort}</td>
                ))}
              </tr>
              <tr class="link-row">
                <th scope="row" class="sr-only">Page de détail</th>
                {maintenanceFormules.map((f) => (
                  <td>
                    <a href={`/maintenance-web/${f.slug}`} class="detail-link">
                      Voir le détail
                    </a>
                  </td>
                ))}
              </tr>
            </tbody>
          </table>
        </div>
      </Reveal>
    </div>
  </section>

  <section class="conditions">
    <div class="container-narrow">
      <Reveal>
        <p class="conditions-text">
          Hébergement et nom de domaine inclus dans toutes nos formules de
          maintenance web. Engagement 12 mois, tacite reconduction. Tarifs nets,
          TVA non applicable, art. 293 B du CGI.
        </p>
        <p class="conditions-doc">
          Plaquette commerciale :
          <a href="/documents/plaquette_le_geai_informatique.pdf" download>
            télécharger le PDF
          </a>
        </p>
      </Reveal>
    </div>
  </section>

  <section class="cta">
    <div class="container-narrow">
      <Reveal>
        <h2>Une question, un site à reprendre</h2>
        <p class="lead">
          Décrivez votre site actuel, ce qui fonctionne, ce qui mérite d'être
          repris. Nous reviendrons avec un cadrage juste.
        </p>
      </Reveal>
      <Reveal delay={150}>
        <div class="cta-row">
          <a href="/contact" class="btn-primary">Demander un cadrage</a>
          <a href="/creation-web" class="btn-ghost">Voir la création</a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page-head {
    padding: 8rem 1.5rem 3rem;
    text-align: center;
  }
  h1 {
    font-size: clamp(2.4rem, 5vw, 3.8rem);
  }
  h2 {
    font-size: clamp(1.6rem, 3vw, 2rem);
    text-align: center;
  }
  .lead {
    max-width: 600px;
    margin: 1.4rem auto 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ── Module 1 : 4 cartes ── */
  .formules-row { padding: 2rem 1.5rem 4rem; }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .card-link { display: block; color: inherit; height: 100%; }
  .card {
    position: relative;
    height: 100%;
    padding: 1.8rem 1.6rem 2.2rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .card-link:hover .card {
    border-color: var(--color-dore);
    transform: translateY(-3px);
  }
  .card h3 {
    font-size: 1.4rem;
    color: var(--color-text);
    margin-bottom: 0.4rem;
  }
  .card-tarif {
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-dore);
    line-height: 1.2;
  }
  .card-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .card-arrow {
    position: absolute;
    bottom: 1rem;
    right: 1.2rem;
    font-size: 1.4rem;
    color: var(--color-text-muted);
    transition: transform 0.3s ease, color 0.3s ease;
  }
  .card-link:hover .card-arrow {
    color: var(--color-dore);
    transform: translateX(4px);
  }

  /* ── Module 2 : Comparator ── */
  .comparator-section {
    padding: 4rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .comparator-title { margin-bottom: 0.8rem; }
  .comparator-hint {
    text-align: center;
    font-style: italic;
    color: var(--color-text-dim);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    background: var(--color-surface-raised);
  }
  .comparator { width: 100%; min-width: 720px; border-collapse: collapse; }

  .formule-col {
    padding: 1.2rem 0.8rem 1.4rem;
    text-align: center;
    background: rgba(201, 169, 97, 0.08);
    border-bottom: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
  }
  .formule-link {
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    color: inherit; transition: color 0.3s ease;
  }
  .formule-link:hover { color: var(--color-dore); }
  .formule-name {
    font-size: 1.2rem; font-style: italic; color: var(--color-dore);
    border-bottom: 1px dotted transparent; padding-bottom: 2px;
    transition: border-color 0.3s ease;
  }
  .formule-link:hover .formule-name { border-bottom-color: var(--color-dore); }
  .formule-tarif { font-size: 0.82rem; letter-spacing: 0.06em; color: var(--color-text-muted); }

  .feature-col { background: rgba(201, 169, 97, 0.04); border-bottom: 1px solid var(--color-border); }
  .feature {
    text-align: left; padding: 0.95rem 1rem;
    color: var(--color-text); font-weight: 500;
    border-bottom: 1px solid var(--color-border);
    background: rgba(201, 169, 97, 0.03);
    width: 28%;
  }

  .group-row th {
    text-align: left; padding: 1rem 1rem 0.6rem;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-dore);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    border-top: 1px solid var(--color-border);
  }

  td {
    padding: 0.95rem 0.8rem; text-align: center;
    border-bottom: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    vertical-align: middle;
  }
  .cell-yes .cell-mark { color: var(--color-dore); font-size: 1.2rem; font-weight: 700; }
  .cell-no .cell-mark { color: var(--color-text-dim); font-size: 1.1rem; }
  .cell-text .cell-value, .cell-text { color: var(--color-text-muted); font-size: 0.95rem; font-style: italic; }

  .summary-row .feature {
    text-transform: uppercase; font-size: 0.78rem; letter-spacing: 0.16em; color: var(--color-dore);
  }
  .summary-row td { background: var(--color-surface); }
  .cell-tarif { font-style: italic; color: var(--color-dore); font-size: 1.05rem; white-space: nowrap; }

  .link-row td { background: var(--color-surface); padding: 1rem 0.5rem 1.4rem; }
  .link-row { border-top: 2px solid var(--color-border); }
  .detail-link {
    display: inline-block; padding: 0.55rem 1rem;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-text); border: 1px solid var(--color-border);
    transition: all 0.3s ease;
  }
  .detail-link:hover { border-color: var(--color-dore); color: var(--color-dore); background: rgba(201, 169, 97, 0.06); }

  /* ── Conditions + CTA ── */
  .conditions { padding: 4rem 1.5rem 2rem; text-align: center; }
  .conditions-text { font-style: italic; color: var(--color-text-muted); line-height: 1.8; }
  .conditions-doc { margin-top: 1.5rem; font-size: 0.9rem; color: var(--color-text-dim); }
  .conditions-doc a { color: var(--color-dore); border-bottom: 1px solid var(--color-border); transition: border-color 0.3s ease; }
  .conditions-doc a:hover { border-bottom-color: var(--color-dore); }

  .cta {
    padding: 6rem 1.5rem;
    background: var(--color-surface-raised);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
  .cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2.5rem; }
  .btn-primary {
    display: inline-block; padding: 0.85rem 2rem;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-noir); background: var(--color-dore); transition: opacity 0.3s ease;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    display: inline-block; padding: 0.85rem 2rem;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-text); border: 1px solid var(--color-border); transition: all 0.4s ease;
  }
  .btn-ghost:hover { border-color: var(--color-dore); color: var(--color-dore); }

  @media (max-width: 1024px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) {
    .cards-grid { grid-template-columns: 1fr; }
    .comparator { font-size: 0.88rem; }
    .feature { padding: 0.7rem 0.7rem; }
    td { padding: 0.7rem 0.5rem; }
    .formule-name { font-size: 1rem; }
  }
</style>
