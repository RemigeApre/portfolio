---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import FormuleDetail from '~/components/FormuleDetail.astro';
import { getFormule, maintenanceFormules } from '~/data/formules';
import { buildHreflang } from '~/lib/i18n';

const formule = getFormule('maintenance', 'legendaire')!;
const index = maintenanceFormules.findIndex((f) => f.slug === formule.slug) + 1;
---

<BaseLayout
  title="Légendaire · Maintenance web 499 € par mois"
  description="Maintenance Légendaire : Premium + 1 h par semaine de gestion active du contenu (ajouts, mises à jour, utilisateurs) + priorité maximale. 499 € par mois, engagement 12 mois."
  hreflang={buildHreflang('/maintenance-web/legendaire', 'fr')}
>
  <FormuleDetail formule={formule} index={index} total={maintenanceFormules.length} />
</BaseLayout>
