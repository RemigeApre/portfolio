---
export const prerender = true;

import BaseLayout from '~/layouts/BaseLayout.astro';
import Reveal from '~/components/Reveal.astro';
import ProtectedEmail from '~/components/ProtectedEmail.astro';
import ProtectedTel from '~/components/ProtectedTel.astro';
import { buildHreflang } from '~/lib/i18n';

const services = [
  { value: 'creation-vitrine', label: 'Création web · Vitrine' },
  { value: 'creation-gestion', label: 'Création web · Gestion' },
  { value: 'creation-e-commerce', label: 'Création web · E-commerce' },
  { value: 'creation-logiciel', label: 'Création web · Logiciel sur mesure' },
  { value: 'maintenance-essentiel', label: 'Maintenance · Essentiel' },
  { value: 'maintenance-pro', label: 'Maintenance · Pro' },
  { value: 'maintenance-premium', label: 'Maintenance · Premium' },
  { value: 'maintenance-legendaire', label: 'Maintenance · Légendaire' },
  { value: 'hesite', label: "J'hésite encore" },
];
---

<BaseLayout
  title="Contact · Le Geai Informatique"
  description="Échangeons sur votre projet. Email, téléphone ou formulaire détaillé. Réponse sous 48h ouvrées. Premier rendez-vous offert."
  hreflang={buildHreflang('/contact', 'fr')}
>
  <header class="page-head">
    <div class="container-narrow">
      <Reveal>
        <h1>Parlons de votre projet</h1>
      </Reveal>
      <Reveal delay={150}>
        <p class="lead">
          Trois portes pour entrer : un email direct, un appel, ou un formulaire
          si vous préférez poser le besoin par écrit. Réponse sous 48h ouvrées.
        </p>
      </Reveal>
    </div>
  </header>

  <section class="contact-grid">
    <div class="container">
      <div class="grid">
        <Reveal class="aside">
          <div class="aside-inner">
            <div class="block">
              <p class="kicker">Direct</p>
              <p class="meta">Réponse sous 48h ouvrées</p>
              <ProtectedEmail
                user="administration"
                domain="legeai-editions.com"
                lang="fr"
                class="big-link"
                fallback="Voir l'adresse →"
              />
              <ProtectedTel
                number="+33482532564"
                display="04 82 53 25 64"
                class="big-link"
              />
            </div>

            <div class="rule" aria-hidden="true"></div>

            <div class="block">
              <p class="kicker">Engagements</p>
              <ul class="commit">
                <li>Premier rendez-vous offert.</li>
                <li>Aucun envoi commercial après l'échange.</li>
                <li>Données conservées pour le suivi du dossier uniquement.</li>
              </ul>
              <p class="meta">
                Voir la <a href="/confidentialite">politique de confidentialité</a>.
              </p>
            </div>
          </div>
        </Reveal>

        <Reveal class="main" delay={120}>
          <h2>Décrire votre besoin</h2>
          <p class="form-lead">
            Quelques minutes suffisent. Tout est enregistré en interne.
          </p>

          <form id="contact-form" class="form" novalidate>
            {/* Honeypot anti-bot : invisible aux humains, rempli par les bots automatisés.
                Le serveur jette silencieusement toute soumission où ce champ contient quelque chose. */}
            <div class="hp" aria-hidden="true">
              <label for="hp-website">Site web (laissez vide)</label>
              <input type="text" id="hp-website" name="website" tabindex="-1" autocomplete="off" />
            </div>
            {/* Timestamp posé par JS au chargement. Permet de détecter une soumission instantanée (bot). */}
            <input type="hidden" name="_ts" id="hp-ts" value="" />

            <fieldset class="fs">
              <legend>Vous</legend>
              <div class="row">
                <label class="field">
                  <span>Nom <em>·</em> requis</span>
                  <input type="text" name="last_name" required autocomplete="family-name" maxlength="200" />
                </label>
                <label class="field">
                  <span>Prénom</span>
                  <input type="text" name="first_name" autocomplete="given-name" maxlength="200" />
                </label>
              </div>
            </fieldset>

            <fieldset class="fs">
              <legend>Comment vous joindre <em class="hint">au moins un</em></legend>
              <div class="row">
                <label class="field">
                  <span>Email</span>
                  <input type="email" name="contact_email" autocomplete="email" />
                </label>
                <label class="field">
                  <span>Téléphone</span>
                  <input type="tel" name="contact_phone" autocomplete="tel" />
                </label>
              </div>
              <label class="field">
                <span>Adresse postale</span>
                <textarea name="contact_postal" rows="2" autocomplete="street-address"></textarea>
              </label>
            </fieldset>

            <fieldset class="fs">
              <legend>Sujet de la demande <em>·</em> requis</legend>
              <div class="radio-group">
                <label class="radio">
                  <input type="radio" name="subject" value="service" required />
                  <span class="radio-mark"></span>
                  <span class="radio-label">Demande sur un service</span>
                </label>
                <label class="radio">
                  <input type="radio" name="subject" value="divers" required />
                  <span class="radio-mark"></span>
                  <span class="radio-label">Sujet divers</span>
                </label>
              </div>
            </fieldset>

            <fieldset class="fs" id="service-fs" hidden>
              <legend>Quel service vous intéresse</legend>
              <label class="field">
                <span>Choisissez dans la liste</span>
                <select name="service_interest">
                  <option value="">— sélectionner —</option>
                  {services.map((s) => (
                    <option value={s.value}>{s.label}</option>
                  ))}
                </select>
              </label>
            </fieldset>

            <fieldset class="fs">
              <legend>Votre message <em class="hint" id="message-req-hint">facultatif si demande de service</em></legend>
              <label class="field">
                <span class="sr-only">Message</span>
                <textarea
                  name="message"
                  rows="6"
                  maxlength="5000"
                  placeholder="Décrivez votre activité, ce que vous cherchez à construire, vos contraintes…"
                ></textarea>
              </label>
            </fieldset>

            <div id="form-error" class="form-error" hidden role="alert"></div>

            <div class="form-actions">
              <button type="submit" class="btn-primary">Envoyer la demande</button>
            </div>
          </form>

          <div id="form-success" class="form-success" hidden>
            <p class="success-icon" aria-hidden="true">✓</p>
            <h3>Demande bien reçue</h3>
            <p>
              Merci. Nous revenons vers vous sous 48h ouvrées sur le moyen de contact
              que vous avez indiqué.
            </p>
            <button type="button" id="form-reset" class="btn-ghost">Envoyer une autre demande</button>
          </div>
        </Reveal>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error') as HTMLElement | null;
  const serviceFs = document.getElementById('service-fs');
  const msgHint = document.getElementById('message-req-hint');
  const resetBtn = document.getElementById('form-reset');

  // Honeypot timestamp : posé au chargement pour mesurer le temps de remplissage
  const tsInput = document.getElementById('hp-ts') as HTMLInputElement | null;
  if (tsInput) tsInput.value = String(Date.now());

  if (!form || !success || !errorBox || !serviceFs || !msgHint) {
    // missing DOM
  } else {
    const subjectRadios = form.querySelectorAll<HTMLInputElement>('input[name="subject"]');
    const messageField = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]');
    const serviceSelect = form.querySelector<HTMLSelectElement>('select[name="service_interest"]');

    const updateConditional = () => {
      const checked = form.querySelector<HTMLInputElement>('input[name="subject"]:checked');
      const v = checked?.value;
      if (v === 'service') {
        serviceFs.removeAttribute('hidden');
        if (serviceSelect) serviceSelect.required = true;
        if (messageField) messageField.required = false;
        msgHint.textContent = 'facultatif';
      } else if (v === 'divers') {
        serviceFs.setAttribute('hidden', '');
        if (serviceSelect) {
          serviceSelect.required = false;
          serviceSelect.value = '';
        }
        if (messageField) messageField.required = true;
        msgHint.textContent = 'requis';
      } else {
        serviceFs.setAttribute('hidden', '');
        if (messageField) messageField.required = false;
        msgHint.textContent = 'facultatif si demande de service';
      }
    };

    subjectRadios.forEach((r) => r.addEventListener('change', updateConditional));
    updateConditional();

    const showError = (msg: string) => {
      errorBox.textContent = msg;
      errorBox.removeAttribute('hidden');
      errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
    };
    const hideError = () => errorBox.setAttribute('hidden', '');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      const data = new FormData(form);
      const payload = Object.fromEntries(data.entries());

      if (!String(payload.last_name ?? '').trim()) {
        showError('Votre nom est requis.');
        return;
      }
      if (
        !String(payload.contact_email ?? '').trim() &&
        !String(payload.contact_phone ?? '').trim() &&
        !String(payload.contact_postal ?? '').trim()
      ) {
        showError('Renseignez au moins un moyen de contact (email, téléphone ou adresse).');
        return;
      }
      if (!payload.subject) {
        showError('Choisissez un sujet.');
        return;
      }
      if (payload.subject === 'service' && !String(payload.service_interest ?? '').trim()) {
        showError('Choisissez un service ou cochez « j\'hésite encore ».');
        return;
      }
      if (payload.subject === 'divers' && !String(payload.message ?? '').trim()) {
        showError('Décrivez votre demande.');
        return;
      }

      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Envoi…';
      }

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json();
        if (res.ok && json.ok) {
          form.setAttribute('hidden', '');
          success.removeAttribute('hidden');
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
          form.reset();
        } else {
          const firstErr = json.errors ? Object.values(json.errors)[0] : json.error;
          showError(String(firstErr ?? 'Une erreur est survenue.'));
        }
      } catch {
        showError('Connexion au serveur impossible. Réessayez dans un instant.');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Envoyer la demande';
        }
      }
    });

    resetBtn?.addEventListener('click', () => {
      success.setAttribute('hidden', '');
      form.removeAttribute('hidden');
      updateConditional();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  .page-head {
    padding: 9rem 1.5rem 3rem;
    text-align: center;
  }
  h1 { font-size: clamp(2.4rem, 5vw, 3.8rem); }
  .lead {
    max-width: 600px;
    margin: 1.4rem auto 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ── Layout 2 colonnes : aside (contact direct) | main (formulaire) ── */
  .contact-grid { padding: 2rem 1.5rem 6rem; }
  .grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 4rem;
    align-items: start;
    max-width: 1100px;
    margin-inline: auto;
  }

  /* ── Aside ── */
  .aside-inner {
    position: sticky;
    top: 7rem;
    padding: 2rem 0 0;
  }
  .block + .block { margin-top: 1.6rem; }
  .kicker {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-dore);
    margin-bottom: 0.4rem;
  }
  .meta {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-text-dim);
    margin-bottom: 1.4rem;
  }
  .meta a {
    color: var(--color-dore);
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.3s ease;
  }
  .meta a:hover { border-bottom-color: var(--color-dore); }

  .big-link {
    display: block;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    font-style: italic;
    color: var(--color-dore);
    margin-bottom: 0.7rem;
    transition: opacity 0.3s ease;
    word-break: break-word;
  }
  .big-link:hover { opacity: 0.75; }
  .big-link + .big-link { margin-top: 0.2rem; }

  .rule {
    width: 32px;
    height: 1px;
    background: var(--color-border);
    margin: 1.8rem 0;
  }

  .commit {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }
  .commit li {
    position: relative;
    padding: 0.4rem 0 0.4rem 1.2rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .commit li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.95rem;
    width: 8px;
    height: 1px;
    background: var(--color-dore);
    opacity: 0.6;
  }

  /* ── Form (main) ── */
  .main h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.7rem);
    margin-bottom: 0.6rem;
  }
  .form-lead {
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .form { display: flex; flex-direction: column; gap: 1.8rem; }
  /* Honeypot : invisible aux humains, présent dans le DOM pour les bots */
  .hp {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .fs {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .fs legend {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-dore);
    margin-bottom: 0.4rem;
  }
  .fs legend em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-dim);
    letter-spacing: 0.05em;
    text-transform: none;
  }
  .fs legend em.hint {
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: none;
    margin-left: 0.5rem;
  }

  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field span {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .field span em {
    font-style: italic;
    color: var(--color-dore);
    font-weight: 700;
    margin: 0 0.2rem;
  }
  .sr-only {
    position: absolute !important;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  input[type="text"], input[type="email"], input[type="tel"],
  textarea, select {
    padding: 0.85rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.6;
    transition: border-color 0.3s ease, background 0.3s ease;
    width: 100%;
  }
  textarea { resize: vertical; min-height: 80px; }
  input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: var(--color-dore);
    background: rgba(26, 26, 26, 0.6);
  }
  select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, var(--color-dore) 50%),
                      linear-gradient(135deg, var(--color-dore) 50%, transparent 50%);
    background-position: calc(100% - 18px) center, calc(100% - 12px) center;
    background-size: 6px 6px, 6px 6px;
    background-repeat: no-repeat;
    padding-right: 2.5rem;
    cursor: pointer;
  }
  select option { background: var(--color-surface); color: var(--color-text); }

  .radio-group { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .radio {
    display: flex; align-items: center; gap: 0.7rem;
    cursor: pointer; padding: 0.5rem 0;
  }
  .radio input { position: absolute; opacity: 0; pointer-events: none; }
  .radio-mark {
    width: 18px; height: 18px;
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    transition: border-color 0.3s ease;
    flex-shrink: 0;
  }
  .radio-mark::after {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-dore);
    transform: scale(0);
    transition: transform 0.2s ease;
  }
  .radio input:checked + .radio-mark { border-color: var(--color-dore); }
  .radio input:checked + .radio-mark::after { transform: scale(1); }
  .radio input:focus-visible + .radio-mark {
    outline: 2px solid var(--color-dore);
    outline-offset: 2px;
  }
  .radio-label { font-size: 0.95rem; color: var(--color-text); }

  .form-error {
    padding: 1rem 1.2rem;
    border: 1px solid #c66;
    background: rgba(170, 60, 60, 0.12);
    color: #f0c4c4;
    font-style: italic;
  }

  .form-actions { margin-top: 0.5rem; }
  .btn-primary {
    display: inline-block;
    padding: 1rem 2.4rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-noir);
    background: var(--color-dore);
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  .btn-primary:hover:not(:disabled) { opacity: 0.85; }
  .btn-primary:disabled { opacity: 0.5; cursor: wait; }

  .form-success {
    text-align: center;
    padding: 3rem 1rem;
    border: 1px solid var(--color-dore);
    background: rgba(201, 169, 97, 0.06);
  }
  .success-icon {
    font-size: 3rem; color: var(--color-dore); line-height: 1;
    margin-bottom: 0.5rem;
  }
  .form-success h3 { font-size: 1.5rem; margin-bottom: 0.8rem; }
  .form-success p {
    color: var(--color-text-muted); line-height: 1.7;
    max-width: 460px; margin: 0 auto 1.8rem;
  }
  .btn-ghost {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all 0.4s ease;
  }
  .btn-ghost:hover { border-color: var(--color-dore); color: var(--color-dore); }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .aside-inner {
      position: static;
      padding-top: 0;
    }
  }
  @media (max-width: 600px) {
    .row { grid-template-columns: 1fr; }
  }
</style>
