# Copier ce fichier en .env, puis adapter les valeurs.
# En dev local : tu peux laisser tel quel.
# En prod sur le VPS : remplace TOUTES les valeurs par des secrets forts (voir README).

# --- Postgres ---
DB_USER=legeai
DB_PASSWORD=dev-password-changemoi
DB_NAME=legeai

# --- Directus ---
# KEY et SECRET : chaines aleatoires, obligatoires pour signer les tokens.
# En prod, generer avec : openssl rand -hex 16  (KEY)  et  openssl rand -hex 32  (SECRET)
DIRECTUS_KEY=dev-key-remplace-en-prod-uuid-aleatoire
DIRECTUS_SECRET=dev-secret-remplace-en-prod-32-bytes-aleatoires

# Compte admin du CMS (interface http://localhost:8055).
# Email avec TLD valide obligatoire (Directus refuse les .local).
DIRECTUS_ADMIN_EMAIL=admin@legeai-informatique.fr
DIRECTUS_ADMIN_PASSWORD=dev-password-changemoi

# URL publique du CMS, utilisee pour les liens et les images chargees par le navigateur.
# Dev : http://localhost:8055
# Prod : https://admin.legeai-informatique.fr
DIRECTUS_PUBLIC_URL=http://localhost:8055

# URL interne du CMS, utilisee par Astro cote serveur (entre containers Docker).
# Ne pas modifier en dev. En prod, garder http://directus:8055.
DIRECTUS_INTERNAL_URL=http://directus:8055

# --- Sécurité ---
# Sel utilisé pour hacher les empreintes IP+UA (rate limiting, anti-spam).
# Si non défini, un sel aléatoire est généré à chaque démarrage (les fingerprints changent à chaque restart).
# En prod : générer une fois avec `openssl rand -hex 32` et garder fixe.
SECURITY_SALT=dev-salt-remplace-en-prod-32-bytes-aleatoires
